# Django Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Optional, falls back to SQLite if empty)
# Use DATABASE_URL for production (e.g. Heroku/Render PostgreSQL)
DATABASE_URL=postgres://user:password@host:port/dbname
DB_SSL_REQUIRE=True
DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Production Security & Allowed Hosts
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# OCR API Configuration (Optional / Future use)
OCR_API_KEY=your-ocr-api-key-here

